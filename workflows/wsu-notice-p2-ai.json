      "id": "c7109876-89cc-49c9-8c26-5646be0d15c6",
      "name": "Google Gemini Chat Model",
      "credentials": {
        "googlePalmApi": {
          "id": "HD07hsVM38qQHLoM",
          "name": "Google Gemini(PaLM) Api account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nconst list = items\n  .map((it, i) => `${i + 1}. ${it.json.title ?? ''}`)\n  .join('\\n');\n\nreturn [{ json: { batch_prompt: list, count: items.length } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -208,
        48
      ],
      "id": "5436329a-1d2b-4b1e-bbc8-da7b6012a043",
      "name": "BuildPrompt"
    },
    {
      "parameters": {
        "jsCode": "const raw = $input.first().json.text ?? '';\n\n// 코드펜스나 앞뒤 군더더기가 붙어도 배열만 추출\nconst m = raw.match(/\\[[\\s\\S]*\\]/);\nif (!m) throw new Error('AI 응답에서 JSON 배열을 찾지 못했습니다: ' + raw.slice(0, 200));\n\nconst parsed = JSON.parse(m[0]);\nconst map = new Map(parsed.map(o => [Number(o.n), o.category]));\n\nconst origin = $('RuleCategory').all();\nconst VALID = ['학사', '공모전', '기타'];\n\nreturn origin.map((it, i) => {\n  const ai = map.get(i + 1);\n  return {\n    json: {\n      ...it.json,\n      category_ai: VALID.includes(ai) ? ai : '분류실패',\n    },\n  };\n});"
      },
